<% layout("/layouts/boilerplate") %>
<style>
  #filters{
    display:flex;
    flex-wrap:wrap;
    align-items:center;
  }
  .filter{
    text-align:center;
    margin-right:2rem;
    margin-top:2rem;
    opacity:0.7; 
  }
  .filter:hover, .active-filter{
    opacity:1;
    cursor:pointer;
  }
  .filter p{
    font-size:0.8rem;
  }
  .tax-info{
    display:none;
  }
  .tax-toggle{
    border:1px solid black;
    border-radius:1rem;
    height:3.2rem;
    padding:1rem;
    margin-left:2rem;
    display:flex;
    align-items:center;
  }
</style>
<body>
  <!-- <h3>All listings</h3> -->
  <div id="map" style="width: 100%; height: 400px; margin-bottom: 2rem; border-radius: 1rem;"></div>

  <div id="filters">
    <a class="filter <%= typeof category !== 'undefined' && category === 'Trending' ? 'active-filter' : '' %>" href="/listings?category=Trending" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-fire"></i></div> 
      <p>Trending</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Rooms' ? 'active-filter' : '' %>" href="/listings?category=Rooms" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-bed"></i></div> 
      <p>Rooms</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Iconic Cities' ? 'active-filter' : '' %>" href="/listings?category=Iconic Cities" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-mountain-city"></i></div> 
      <p>Iconic Cities</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Mountains' ? 'active-filter' : '' %>" href="/listings?category=Mountains" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-mountain"></i></div> 
      <p>Mountains</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Castles' ? 'active-filter' : '' %>" href="/listings?category=Castles" style="text-decoration:none; color:inherit;">
     <div><i class="fa-brands fa-fort-awesome"></i></div> 
      <p>Castles</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Amazing pools' ? 'active-filter' : '' %>" href="/listings?category=Amazing pools" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-person-swimming"></i></div> 
      <p>Amazing pools</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Camping' ? 'active-filter' : '' %>" href="/listings?category=Camping" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-campground"></i></div> 
      <p>Camping</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Farms' ? 'active-filter' : '' %>" href="/listings?category=Farms" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-cow"></i></div> 
      <p>Farms</p>
    </a>
    <a class="filter <%= typeof category !== 'undefined' && category === 'Arctic' ? 'active-filter' : '' %>" href="/listings?category=Arctic" style="text-decoration:none; color:inherit;">
     <div><i class="fa-solid fa-snowflake"></i></div> 
      <p>Arctic</p>
    </a>
    
    <div class="dropdown" style="margin-left: 2rem;">
      <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa-solid fa-filter"></i> Filters
      </button>
      <div class="dropdown-menu p-3" style="width: 250px;">
        <form action="/listings" method="GET">
          <% if(typeof q !== 'undefined' && q){ %><input type="hidden" name="q" value="<%=q%>"><% } %>
          <% if(typeof category !== 'undefined' && category){ %><input type="hidden" name="category" value="<%=category%>"><% } %>
          <div class="mb-2">
            <label class="form-label">Min Price (₹)</label>
            <input type="number" name="minPrice" class="form-control form-control-sm" value="<%= typeof minPrice !== 'undefined' ? minPrice : '' %>">
          </div>
          <div class="mb-2">
            <label class="form-label">Max Price (₹)</label>
            <input type="number" name="maxPrice" class="form-control form-control-sm" value="<%= typeof maxPrice !== 'undefined' ? maxPrice : '' %>">
          </div>
          <div class="mb-2">
            <label class="form-label">Country</label>
            <input type="text" name="country" class="form-control form-control-sm" value="<%= typeof country !== 'undefined' ? country : '' %>">
          </div>
          <button type="submit" class="btn btn-dark btn-sm w-100">Apply Filters</button>
        </form>
      </div>
    </div>

    <div class="tax-toggle"><div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% if (allListings.length === 0) { %>
      <div class="col-12 mt-4 text-center">
        <h4>No listings found <%- typeof q !== 'undefined' && q ? `matching "<b>${q}</b>"` : "" %></h4>
        <p>Try searching for a different destination, or <a href="/listings">explore all listings</a>.</p>
      </div>
    <% } %>
    <% for (let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          style="height: 20rem"
          alt="listing_image"
        />

        <div class="card-img-overlay"></div>

        <div class="card-body">
          <p>
            <b><%= listing.title %></b><br />
            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
          </p>
        </div>
      </div>
    </a>
    <% } %>
  </div>

  <!-- Pagination -->
  <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <nav aria-label="Page navigation" class="mt-4">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="/listings?page=<%= currentPage - 1 %><%- typeof q !== 'undefined' && q ? `&q=${q}` : '' %><%- typeof category !== 'undefined' && category ? `&category=${category}` : '' %><%- typeof minPrice !== 'undefined' && minPrice ? `&minPrice=${minPrice}` : '' %><%- typeof maxPrice !== 'undefined' && maxPrice ? `&maxPrice=${maxPrice}` : '' %><%- typeof country !== 'undefined' && country ? `&country=${country}` : '' %>">Previous</a>
        </li>
        <% for(let i = 1; i <= totalPages; i++) { %>
          <li class="page-item <%= currentPage === i ? 'active' : '' %>">
            <a class="page-link" href="/listings?page=<%= i %><%- typeof q !== 'undefined' && q ? `&q=${q}` : '' %><%- typeof category !== 'undefined' && category ? `&category=${category}` : '' %><%- typeof minPrice !== 'undefined' && minPrice ? `&minPrice=${minPrice}` : '' %><%- typeof maxPrice !== 'undefined' && maxPrice ? `&maxPrice=${maxPrice}` : '' %><%- typeof country !== 'undefined' && country ? `&country=${country}` : '' %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="/listings?page=<%= currentPage + 1 %><%- typeof q !== 'undefined' && q ? `&q=${q}` : '' %><%- typeof category !== 'undefined' && category ? `&category=${category}` : '' %><%- typeof minPrice !== 'undefined' && minPrice ? `&minPrice=${minPrice}` : '' %><%- typeof maxPrice !== 'undefined' && maxPrice ? `&maxPrice=${maxPrice}` : '' %><%- typeof country !== 'undefined' && country ? `&country=${country}` : '' %>">Next</a>
        </li>
      </ul>
    </nav>
  <% } %>
</body>


<script>
  let taxSwitch=document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click",()=>{
    let taxInfo =document.getElementsByClassName('tax-info');
    for(info of taxInfo){
      if(info.style.display!="inline"){
        info.style.display="inline";
      }else{
        info.style.display="none";
      }
      
  })
</script>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const listings = <%- JSON.stringify(allFilteredListings) %>;
</script>
<script src="/js/clusterMap.js"></script>